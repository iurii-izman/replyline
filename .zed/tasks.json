[
  {
    "label": "test:quick (typecheck + lint + ui)",
    "command": "pnpm test:quick",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["test", "gate"]
  },
  {
    "label": "smoke (full gate)",
    "command": "pnpm smoke",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["test", "gate", "heavy"]
  },
  {
    "label": "verify (smoke + security)",
    "command": "pnpm verify",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["test", "gate", "heavy"]
  },
  {
    "label": "typecheck (tsc)",
    "command": "pnpm typecheck",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check"]
  },
  {
    "label": "lint (eslint)",
    "command": "pnpm lint",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check"]
  },
  {
    "label": "test:ui (vitest)",
    "command": "pnpm test:ui",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["test"]
  },
  {
    "label": "test:ui current file",
    "command": "pnpm vitest run $ZED_RELATIVE_FILE",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["test", "file"]
  },
  {
    "label": "test:rust (cargo test)",
    "command": "cargo test --manifest-path src-tauri/Cargo.toml",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["test", "rust"]
  },
  {
    "label": "check:rust (cargo check)",
    "command": "cargo check --manifest-path src-tauri/Cargo.toml",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check", "rust"]
  },
  {
    "label": "clippy (rust lint)",
    "command": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check", "rust"]
  },
  {
    "label": "rust:deps (audit)",
    "command": "pnpm rust:deps",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check", "rust", "heavy"]
  },
  {
    "label": "audit:npm",
    "command": "pnpm audit:npm",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check", "heavy"]
  },
  {
    "label": "format:check (prettier)",
    "command": "pnpm format:check",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check"]
  },
  {
    "label": "dev (vite)",
    "command": "pnpm dev",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["run"]
  },
  {
    "label": "build (vite)",
    "command": "pnpm build",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["build"]
  },
  {
    "label": "consistency check",
    "command": "pnpm test:consistency",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check"]
  },
  {
    "label": "prompt contract check",
    "command": "pnpm test:prompt-contract",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check"]
  },
  {
    "label": "copy check",
    "command": "pnpm copy:check",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check"]
  },
  {
    "label": "validate zed config",
    "command": "node -e \"JSON.parse(require('fs').readFileSync('.zed/settings.json','utf8')); JSON.parse(require('fs').readFileSync('.zed/tasks.json','utf8')); JSON.parse(require('fs').readFileSync('.zed/keymap.json','utf8')); console.log('All .zed JSON OK')\"",
    "cwd": "$ZED_WORKTREE_ROOT",
    "tags": ["check", "zed"]
  }
]
