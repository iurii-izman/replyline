{
  "formatter": "prettier",
  "format_on_save": "on",
  "tab_size": 2,
  "hard_tabs": false,
  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 100,

  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_value_hints": true,
    "show_other_hints": true,
  },

  "code_actions_on_format": {
    "source.fixAll.eslint": true,
    "source.organizeImports": true,
  },

  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 600,
    },
  },

  "project_panel": {
    "auto_reveal": true,
    "auto_fold_dirs": false,
    "default_width": 280,
  },

  "languages": {
    "TypeScript": {
      "formatter": {
        "external": { "command": "prettier", "arguments": ["--stdin-filepath", "{buffer_path}"] },
      },
      "language_servers": ["typescript-language-server"],
      "inlay_hints": {
        "enabled": true,
        "show_type_hints": true,
        "show_parameter_hints": true,
        "show_value_hints": false,
        "show_other_hints": true,
      },
    },
    "TSX": {
      "formatter": {
        "external": { "command": "prettier", "arguments": ["--stdin-filepath", "{buffer_path}"] },
      },
      "language_servers": ["typescript-language-server"],
      "inlay_hints": {
        "enabled": true,
        "show_type_hints": true,
        "show_parameter_hints": true,
        "show_value_hints": false,
        "show_other_hints": true,
      },
    },
    "Rust": {
      "language_servers": ["rust-analyzer"],
      "inlay_hints": {
        "enabled": true,
        "show_type_hints": true,
        "show_parameter_hints": true,
        "show_value_hints": false,
        "show_other_hints": true,
      },
    },
    "JSON": {
      "formatter": {
        "external": { "command": "prettier", "arguments": ["--stdin-filepath", "{buffer_path}"] },
      },
    },
    "Markdown": {
      "soft_wrap": "editor_width",
    },
  },

  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "cargo": {
          "targetDir": "src-tauri/target",
        },
        "completion": {
          "snippets": {
            "custom": {
              "Tauri command": {
                "postfix": "tauricmd",
                "body": [
                  "#[tauri::command]",
                  "fn ${1:name}() -> Result<${2:String}, String> {",
                  "    Ok(${3:todo!()})",
                  "}",
                ],
                "scope": "scope",
              },
              "Tauri state command": {
                "postfix": "tauristate",
                "body": [
                  "#[tauri::command]",
                  "fn ${1:name}(state: tauri::State<'_, ${2:AppState}>) -> Result<${3:String}, String> {",
                  "    Ok(${4:todo!()})",
                  "}",
                ],
                "scope": "scope",
              },
              "Match with catch": {
                "postfix": "matchall",
                "body": [
                  "match ${1:expr} {",
                  "    ${2:pattern} => ${3:expr},",
                  "    other => {",
                  "        tracing::warn!(reason = ?other, \"unexpected ${1:expr}\");",
                  "        ${4:default}",
                  "    }",
                  "}",
                ],
                "scope": "expr",
              },
            },
          },
        },
      },
    },
  },

  "assistant": {
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-5-sonnet",
    },
    "version": "2",
  },
  "agent": {
    "enabled": true,
    "dock": "right",
    "default_width": 640,
    "default_height": 320,
    "single_file_review": true,
    "notify_when_agent_waiting": true,
    "play_sound_when_agent_done": false,
    "communication": {
      "language": "ru",
      "note": "Общение на русском. Технические термины на английском. Англицизмы допустимы. Комментарии в коде и коммит-месседжи — на английском.",
    },
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "terminal": {
          "default": "allow",
          "always_allow": [
            { "pattern": "^pnpm" },
            { "pattern": "^cargo" },
            { "pattern": "^git" },
            { "pattern": "^node" },
            { "pattern": "^pwsh" },
          ],
          "always_deny": [{ "pattern": "rm -rf" }, { "pattern": "sudo rm" }],
        },
        "edit_file": {
          "always_deny": [{ "pattern": ".env" }, { "pattern": ".pem" }],
        },
      },
    },
    "profiles": {
      "readonly": {
        "name": "Read Only",
        "tools": {
          "read_file": true,
          "grep": true,
          "list_directory": true,
          "find_path": true,
          "diagnostics": true,
          "fetch": true,
          "edit_file": false,
          "terminal": false,
          "delete_path": false,
        },
      },
      "edit-safe": {
        "name": "Safe Edit",
        "tools": {
          "read_file": true,
          "grep": true,
          "list_directory": true,
          "find_path": true,
          "diagnostics": true,
          "fetch": true,
          "edit_file": true,
          "terminal": true,
          "delete_path": false,
        },
      },
      "write": {
        "name": "Write (autopilot)",
        "tools": {
          "read_file": true,
          "grep": true,
          "list_directory": true,
          "find_path": true,
          "diagnostics": true,
          "fetch": true,
          "edit_file": true,
          "terminal": true,
          "delete_path": true,
        },
      },
    },
  },

  "terminal": {
    "shell": {
      "program": "pwsh",
    },
    "working_directory": "current_project_directory",
    "dock": "bottom",
    "default_height": 320,
  },

  "file_finder": {
    "exclude_patterns": [
      "node_modules/",
      "dist/",
      "target/",
      "src-tauri/target/",
      "coverage/",
      "test-results/",
      "reports/",
      "artifacts/",
      "*.log",
      "*.tmp",
      "*.zip",
      "*.7z",
      "*.wav",
      "*.mp3",
      "*.mp4",
      "*.webm",
      ".env",
      ".env.*",
      ".env.keys",
    ],
  },
}
