{
  "name": "replyline",
  "version": "0.2.0-beta.3",
  "description": "Replyline — Windows-first tray app для сложных рабочих разговоров (public source beta, RU-first UX).",
  "packageManager": "pnpm@9.15.9",
  "type": "module",
  "pnpm": {
    "overrides": {
      "postcss": "8.5.14",
      "flatted": "3.4.2",
      "lodash": "4.18.1",
      "tmp": "0.2.7",
      "uuid": "11.1.1",
      "qs": "6.15.2",
      "serialize-javascript": "7.0.5",
      "ws@>=7.0.0 <7.5.11": "7.5.11",
      "undici": "7.28.0"
    },
    "onlyBuiltDependencies": [
      "edgedriver",
      "esbuild",
      "geckodriver",
      "protobufjs"
    ]
  },
  "scripts": {
    "// ── Dev ──": "",
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "tauri": "tauri",
    "// ── Verification profiles (public) ──": "",
    "test:quick": "pnpm typecheck && pnpm lint && pnpm test:ui",
    "verify": "pnpm smoke && pnpm test:security-lanes && pnpm test:public-footprint",
    "verify:full": "pnpm verify && pnpm scripts:lifecycle && pnpm release:freeze:check:strict && pnpm rust:deps && pnpm audit:npm && pnpm test:quality && pnpm report:runtime-quality:strict && pnpm report:release-readiness:strict",
    "verify:extended": "pnpm test:ui:coverage && pnpm test:fixtures && pnpm test:fixture-gate && pnpm test:e2e:web:smoke && pnpm test:e2e:web:visual && pnpm test:e2e:desktop && pnpm test:sec:zap && pnpm test:ux:lighthouse",
    "// ── Building blocks (internal) ──": "",
    "smoke": "pnpm typecheck && pnpm lint && pnpm build && cargo check --manifest-path src-tauri/Cargo.toml && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings && cargo fmt --manifest-path src-tauri/Cargo.toml --check && pnpm test:unit && pnpm test:contracts",
    "test:unit": "pnpm test:rust && pnpm test:ui && pnpm test:latency-parser && pnpm test:runtime-answer-quality:unit && pnpm test:product-scenarios:unit && pnpm test:release-freeze-guard && pnpm test:public-footprint-guard && pnpm test:beta-health-report && pnpm test:beta-smoke-report && pnpm test:report-release-readiness && pnpm test:report-runtime-quality-summary",
    "test:contracts": "pnpm test:consistency && pnpm test:doc-links && pnpm test:ipc-contract && pnpm test:locale-keys && pnpm test:prompt-contract && pnpm copy:check",
    "test:quality": "pnpm test:interview-quality && pnpm check:runtime-answer-quality && pnpm check:product-scenarios && pnpm check:say-now-scenarios && pnpm check:slo",
    "// ── Typecheck / lint / format ──": "",
    "typecheck": "pwsh -NoProfile -Command \"tsc --noEmit -p tsconfig.node.json; $code = $LASTEXITCODE; if (Test-Path 'tsconfig.node.tsbuildinfo') { Remove-Item 'tsconfig.node.tsbuildinfo' -Force }; exit $code\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "// ── Contract checks ──": "",
    "test:consistency": "pnpm test:contracts:docs && pnpm test:contracts:ui && pnpm test:contracts:model && pnpm test:contracts:runtime && pnpm test:contracts:observability && pnpm test:contracts:beta",
    "test:contracts:docs": "node scripts/check-consistency.mjs",
    "test:contracts:ui": "node scripts/check-ui-shell-contract.mjs",
    "test:contracts:model": "node scripts/check-model-preset-contract.mjs",
    "test:contracts:runtime": "node scripts/check-runtime-preflight-contract.mjs && node scripts/verify-live-runtime-evidence.test.mjs",
    "test:contracts:observability": "node scripts/check-observability-events-contract.mjs",
    "test:contracts:beta": "pnpm test:beta-doctor && pnpm test:beta-start",
    "test:doc-links": "node scripts/check-doc-links.mjs",
    "test:ipc-contract": "node scripts/check-ipc-handler-contract.mjs",
    "test:locale-keys": "node scripts/check-locale-keys.mjs",
    "test:prompt-contract": "node scripts/check-prompt-contract.mjs",
    "copy:check": "node scripts/copy-check.mjs",
    "test:public-footprint": "node scripts/check-public-footprint.mjs && node scripts/check-report-secret-leaks.mjs",
    "test:security-lanes": "node scripts/check-security-lanes.mjs",
    "scripts:lifecycle": "node scripts/check-script-lifecycle.mjs",
    "// ── UI tests ──": "",
    "test:ui": "vitest run --maxWorkers=1",
    "test:ui:coverage": "vitest run --coverage",
    "// ── Unit / quality tests ──": "",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:latency-parser": "node scripts/parse-pipeline-latency.test.mjs",
    "test:runtime-answer-quality:unit": "node scripts/evaluate-runtime-answer-quality.test.mjs",
    "test:product-scenarios:unit": "node scripts/evaluate-product-scenarios.test.mjs",
    "test:release-freeze-guard": "node scripts/check-release-freeze.test.mjs",
    "test:public-footprint-guard": "node scripts/check-public-footprint.test.mjs",
    "test:beta-doctor": "node scripts/beta-doctor.test.mjs",
    "test:beta-health-report": "node scripts/beta-health-report.test.mjs",
    "test:beta-start": "node scripts/beta-start.test.mjs",
    "test:beta-smoke-report": "node scripts/beta-smoke-report.test.mjs",
    "test:beta-feedback": "node scripts/beta-feedback.test.mjs",
    "test:report-release-readiness": "node scripts/report-release-readiness.test.mjs",
    "test:report-runtime-quality-summary": "node scripts/report-runtime-quality-summary.test.mjs",
    "test:interview-quality": "node scripts/test-interview-quality.mjs",
    "test:fixtures": "node scripts/check-fixtures.mjs",
    "test:fixture-gate": "node scripts/run-fixture-gate.mjs",
    "test:report-secret-leaks": "node scripts/check-report-secret-leaks.mjs",
    "// ── Quality checks ──": "",
    "check:runtime-answer-quality": "node scripts/evaluate-runtime-answer-quality.mjs",
    "check:product-scenarios": "node scripts/evaluate-product-scenarios.mjs",
    "check:say-now-scenarios": "node scripts/check-say-now-scenarios.mjs",
    "check:slo": "node scripts/check-slo-budget.mjs",
    "// ── E2E (optional tooling) ──": "",
    "test:e2e:web:smoke": "node scripts/run-optional-lane.mjs --tool pnpm --checkPackage @playwright/test --exec pnpm -- exec playwright test tests/e2e/web/smoke.spec.ts",
    "test:e2e:web:visual": "node scripts/run-optional-lane.mjs --tool pnpm --checkPackage @playwright/test --exec pnpm -- exec playwright test tests/e2e/web/visual.spec.ts",
    "test:e2e:web:required": "pnpm exec playwright test tests/e2e/web/smoke.spec.ts",
    "test:e2e:desktop": "node scripts/run-optional-lane.mjs --tool tauri-desktop-e2e --checkPackage webdriverio --checkEnv TAURI_APP_PATH --exec pnpm -- exec wdio run tests/e2e/desktop/wdio.tauri.conf.mjs",
    "test:e2e:desktop:required": "node scripts/run-required-desktop-e2e.mjs",
    "test:sec:zap": "node scripts/run-optional-lane.mjs --tool zap-baseline --checkPath scripts/run-zap-baseline.ps1 --exec pwsh -- -File scripts/run-zap-baseline.ps1",
    "test:ux:lighthouse": "node scripts/run-optional-lane.mjs --tool lhci --checkPackage lhci --exec pnpm -- exec lhci autorun --config=./lighthouserc.json",
    "// ── Runtime probes / evidence ──": "",
    "probe:runtime": "cargo run --manifest-path src-tauri/Cargo.toml --bin runtime_probe",
    "probe:bench": "pwsh -File scripts/runtime-bench.ps1",
    "probe:durations": "pwsh -File scripts/runtime-duration-bench.ps1",
    "probe:live-source": "pwsh -File scripts/runtime-live-source-bench.ps1",
    "probe:soak": "pwsh -File scripts/runtime-soak.ps1",
    "evidence:bundle": "pwsh -File scripts/runtime-evidence-bundle.ps1",
    "runtime:preflight": "pwsh -File scripts/runtime-preflight.ps1",
    "parse:latency": "node scripts/parse-pipeline-latency.mjs",
    "// ── Beta operator tooling ──": "",
    "beta:handoff": "pwsh -File scripts/beta-handoff-bundle.ps1",
    "beta:doctor": "node scripts/beta-doctor.mjs",
    "beta:health-report": "node scripts/beta-health-report.mjs",
    "beta:smoke-report": "pwsh -File scripts/beta-smoke-report.ps1",
    "beta:feedback": "node scripts/beta-feedback.mjs",
    "beta:release-check": "pwsh -File scripts/beta-release-check.ps1",
    "beta:start": "node scripts/beta-start.mjs",
    "beta:preflight": "pnpm runtime:preflight && pnpm probe:runtime && pnpm evidence:bundle",
    "// ── Dependency security ──": "",
    "rust:deny": "pwsh -NoProfile -Command \"Push-Location src-tauri; cargo deny check --config deny.toml advisories bans sources; $code = $LASTEXITCODE; Pop-Location; exit $code\"",
    "rust:audit": "cargo audit --quiet --file src-tauri/Cargo.lock",
    "rust:deps": "pnpm rust:deny && pnpm rust:audit",
    "audit:npm": "pnpm audit --prod --audit-level=high",
    "deps:review": "node scripts/review-dependency-freshness.mjs",
    "// ── Reports ──": "",
    "report:runtime-quality:strict": "node scripts/report-runtime-quality-summary.mjs",
    "report:release-readiness": "node scripts/report-release-readiness.mjs",
    "report:release-readiness:strict": "node scripts/report-release-readiness.mjs --strict",
    "report:interview-quality:strict": "node scripts/report-interview-quality.mjs",
    "report:runtime-answer-quality": "node scripts/evaluate-runtime-answer-quality.mjs --report-only",
    "report:product-quality": "node scripts/evaluate-product-scenarios.mjs --report-only",
    "report:card-quality": "node scripts/runtime-card-quality-report.mjs",
    "report:sonar-residual": "node scripts/report-sonar-residual-readiness.mjs",
    "report:live-evidence-pack": "node scripts/report-live-evidence-pack.mjs",
    "report:internal-beta-seal": "node scripts/report-internal-beta-seal.mjs",
    "// ── Release freeze ──": "",
    "release:freeze:check": "node scripts/check-release-freeze.mjs",
    "release:freeze:check:strict": "node scripts/check-release-freeze.mjs --strict"
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/user-event": "^14.6.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "edgedriver": "6.3.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@wdio/cli": "^9.29.1",
    "webdriverio": "^9.29.1"
  }
}
