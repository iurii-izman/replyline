# Replyline project secrets
# Each line = a secret name to load from PowerShell SecretStore (DevVault)
# Usage: . ~/.dev-secrets/Load-ProjectSecrets.ps1; Load-ProjectSecrets

# STT provider
DEEPGRAM_API_KEY

# LLM provider (OpenRouter)
OPENROUTER_API_KEY

# GitHub (for gh CLI, CI management)
GITHUB_CLASSIC_API_KEY
